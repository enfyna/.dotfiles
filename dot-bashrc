rand=$((91 + $RANDOM % 6))
git_branch() {
    local branch=$(git branch 2> /dev/null | grep -e '^\*' | sed -E 's/^\*\ (.+)$/(\1)/')
    local length=${#branch}
    if [[ length -eq 0 ]] then
        echo " "
    else
        echo " $branch "
    fi
}

